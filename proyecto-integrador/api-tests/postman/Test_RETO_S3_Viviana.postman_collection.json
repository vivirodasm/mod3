            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status es 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"El nombre actualizado coincide con el enviado\", function () {\r",
              "    const responseBody = pm.response.json();\r",
              "    const expectedName = pm.collectionVariables.get(\r",
              "        \"updated_user_name\"\r",
              "    );\r",
              "\r",
              "    pm.expect(responseBody.name).to.eql(expectedName);\r",
              "});\r",
              "\r",
              "pm.test(\"El username actualizado coincide\", function () {\r",
              "    const responseBody = pm.response.json();\r",
              "    pm.expect(responseBody.username).to.eql(\"updated_user\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
