  "item": [
    {
      "name": "01 - GET Lista de usuarios",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status es 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"La respuesta contiene 10 usuarios\", function () {\r",
              "    const users = pm.response.json();\r",
              "\r",
              "    pm.expect(users).to.be.an(\"array\");\r",
              "    pm.expect(users.length).to.eql(10);\r",
              "});\r",
              "\r",
              "pm.test(\"El tiempo de respuesta es menor a 2000 ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
    {
      "name": "02 - GET Usuario por ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status es 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const userSchema = {\r",
              "    type: \"object\",\r",
              "    required: [\r",
              "        \"id\",\r",
              "        \"name\",\r",
              "        \"username\",\r",
              "        \"email\"\r",
              "    ],\r",
              "    properties: {\r",
              "        id: {\r",
              "            type: \"integer\"\r",
              "        },\r",
              "        name: {\r",
              "            type: \"string\"\r",
              "        },\r",
              "        username: {\r",
              "            type: \"string\"\r",
              "        },\r",
              "        email: {\r",
              "            type: \"string\"\r",
              "        }\r",
              "    }\r",
              "};\r",
              "\r",
              "pm.test(\"El usuario cumple el JSON Schema\", function () {\r",
              "    pm.response.to.have.jsonSchema(userSchema);\r",
              "});\r",
              "\r",
              "pm.test(\"El usuario devuelto tiene id 1\", function () {\r",
              "    const user = pm.response.json();\r",
              "\r",
              "    pm.expect(user.id).to.eql(1);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "1"
          ]
        }
      },
      "response": []
    },
    {
      "name": "03 - POST Crear usuario",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const dynamicName = \"Usuario QA \" + Date.now();\r",
              "\r",
              "pm.collectionVariables.set(\r",
              "    \"dynamic_user_name\",\r",
              "    dynamicName\r",
              ");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status es 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"El nombre enviado coincide con el nombre devuelto\", function () {\r",
              "    const responseBody = pm.response.json();\r",
              "    const expectedName = pm.collectionVariables.get(\r",
              "        \"dynamic_user_name\"\r",
              "    );\r",
              "\r",
              "    pm.expect(responseBody.name).to.eql(expectedName);\r",
              "});\r",
              "\r",
              "pm.test(\"La respuesta contiene un id\", function () {\r",
              "    const responseBody = pm.response.json();\r",
              "    pm.expect(responseBody).to.have.property(\"id\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"name\": \"{{dynamic_user_name}}\",\r\n  \"username\": \"qa_user\",\r\n  \"email\": \"qa_user@example.com\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/users",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
