{
  "info": {
    "_postman_id": "s3-qa-course-crud-2026",
    "name": "S3 · CRUD JSONPlaceholder",
    "description": "Sesión 3 — Flujo CRUD completo sobre JSONPlaceholder.\nDemuestra: variables de entorno, pre-request scripts, tests en JavaScript y validación con JSON Schema.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 · GET Listar posts",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status es 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Responde en menos de 2 segundos', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "pm.test('El header Content-Type es JSON', function () {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});",
              "",
              "pm.test('Devuelve la lista completa de 100 posts', function () {",
              "    const posts = pm.response.json();",
              "    pm.expect(posts).to.be.an('array');",
              "    pm.expect(posts).to.have.lengthOf(100);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/posts",
          "host": ["{{base_url}}"],
          "path": ["posts"]
        }
      },
      "response": []
    },
    {
      "name": "02 · GET Detalle de un post",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status es 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Contrato de la API: si la estructura cambia, este test falla",
              "const postSchema = {",
              "    type: 'object',",
              "    required: ['userId', 'id', 'title', 'body'],",
              "    properties: {",
              "        userId: { type: 'integer' },",
              "        id: { type: 'integer' },",
              "        title: { type: 'string' },",
              "        body: { type: 'string' }",
              "    }",
              "};",
              "",
              "pm.test('El post cumple el contrato (JSON Schema)', function () {",
              "    pm.response.to.have.jsonSchema(postSchema);",
              "});",
              "",
              "pm.test('El post pedido es el id=1', function () {",
              "    pm.expect(pm.response.json().id).to.eql(1);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/posts/1",
          "host": ["{{base_url}}"],
          "path": ["posts", "1"]
        }
      },
      "response": []
    },
    {
      "name": "03 · POST Crear post",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Se ejecuta ANTES de enviar el request: genera un título único",
              "const titulo = 'Post QA ' + Date.now();",
              "pm.collectionVariables.set('dynamic_title', titulo);",
              "console.log('Título generado:', titulo);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status es 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('El post creado tiene un id asignado', function () {",
              "    const post = pm.response.json();",
              "    pm.expect(post.id).to.be.a('number');",
              "    // Encadenamiento: el id queda disponible para requests siguientes",
              "    pm.collectionVariables.set('post_id', post.id);",
              "});",
              "",
              "pm.test('El título devuelto es el que enviamos', function () {",
              "    const enviado = pm.collectionVariables.get('dynamic_title');",
              "    pm.expect(pm.response.json().title).to.eql(enviado);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"{{dynamic_title}}\",\n  \"body\": \"Creado desde la Sesión 3 del curso\",\n  \"userId\": 1\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/posts",
          "host": ["{{base_url}}"],
          "path": ["posts"]
        }
      },
      "response": []
    },
    {
      "name": "04 · PUT Actualizar post",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status es 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('El título quedó actualizado', function () {",
              "    pm.expect(pm.response.json().title).to.eql('Título actualizado en Sesión 3');",
              "});",
              "",
              "pm.test('El body quedó actualizado', function () {",
              "    pm.expect(pm.response.json().body).to.include('actualizado');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": 1,\n  \"title\": \"Título actualizado en Sesión 3\",\n  \"body\": \"Contenido actualizado desde Postman\",\n  \"userId\": 1\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/posts/1",
          "host": ["{{base_url}}"],
          "path": ["posts", "1"]
        }
      },
      "response": []
    },
    {
      "name": "05 · DELETE Eliminar post",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status es 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('El cuerpo de la respuesta es un objeto vacío', function () {",
              "    pm.expect(pm.response.json()).to.eql({});",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/posts/1",
          "host": ["{{base_url}}"],
          "path": ["posts", "1"]
        }
      },
      "response": []
    },
    {
      "name": "06 · GET Post inexistente (caso negativo)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Caso negativo: pedir un recurso que NO existe debe dar 404",
              "pm.test('Status es 404 Not Found', function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "",
              "pm.test('El cuerpo de la respuesta es un objeto vacío', function () {",
              "    pm.expect(pm.response.json()).to.eql({});",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/posts/999999",
          "host": ["{{base_url}}"],
          "path": ["posts", "999999"]
        }
      },
      "response": []
    }
  ],
  "variable": [
    { "key": "dynamic_title", "value": "" },
    { "key": "post_id", "value": "" }
  ]
}
